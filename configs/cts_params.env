# ============================================================
# cts_params.env — 3D CTS parameters (V58)
#
# Non-macro defaults. Macro designs (swerv_wrapper, ariane133)
# override specific variables in their run.sh.
# ============================================================

# --- Identity ---
export DESIGN_DIMENSION="3D"
export USE_FLOW="openroad"
export FLOW_VARIANT="openroad"
export HETEROGENEOUS_3D="${HETEROGENEOUS_3D:-0}"

# --- Phase skip controls ---
export ENABLE_PROPAGATED_CTS=1           # Phase 1+2: propagated-clock extraction + LP solve
export ENABLE_POST_CTS_LP="${ENABLE_POST_CTS_LP:-0}"  # Phase 3b: post-CTS LP (gain <200ps — not worth solve time)
export CTS_REUSE_TIMING_GRAPH="${CTS_REUSE_TIMING_GRAPH:-1}"  # 1=skip Phase 1 if CSVs exist (save time on re-runs)

# --- CTS flow control ---
export ENABLE_BUFFER_INSERTION=0         # Relay buffer insertion (disabled since V33)
export ENABLE_BUFFER_SIZING=1            # Post-CTS buffer sizing LP
export BUFFER_SIZING_ITERATIVE=1         # Iterative buffer sizing (Liberty-based)
export CTS_ENABLE_DEBUG_EXTRACT=1        # Extract debug CSVs after CTS
export ENABLE_HOLD_REPAIR="${ENABLE_HOLD_REPAIR:-0}"  # Data-path hold repair (Phase 6)

# --- Macro design controls (override in run.sh for swerv/ariane) ---
# CTS_NO_INSERTION_DELAY: 1 = add -no_insertion_delay to clock_tree_synthesis.
#   Disables LatencyBalancer. Required for macro designs with many SRAMs
#   (28 macros + LatencyBalancer ON = 226 delay buffers = catastrophic hold).
#   Non-macro designs: leave 0 (LatencyBalancer balances macro/reg tree latency).
export CTS_NO_INSERTION_DELAY="${CTS_NO_INSERTION_DELAY:-0}"
# CTS_FORCE_MACRO_REG_SPLIT: forces macro/register split even with -no_insertion_delay.
# CTS_FORCE_BOTH_TIER_BUF: uses both-tier buf_list regardless of FF tier ratio.
# CTS_FORCE_ROOT_TIER: forces root buffer tier (0=bottom).
# These are read by C++ via getenv(). Set in macro run.sh, not here.

# --- LP solver (C++ OR-Tools GLOP, endpoint-TNS, 2-phase) ---
export PRE_CTS_ENABLE_2PHASE=1           # Phase A: minimize WNS, Phase B: minimize TNS with WNS bound
export PRE_CTS_WNS_ALPHA=0.05            # Phase B: allow 5% WNS relaxation from Phase A optimal
export PRE_CTS_GAMMA_WNS=10.0            # WNS minimax penalty weight (single-phase fallback)
export PRE_CTS_HARD_PI_HOLD=0            # 0 = soft PI→FF hold (propagated-clock slacks already encode latency)
export PRE_CTS_SIGMA_PI=0.005            # 5ps PI→FF hold safety margin for PI-hold-clip
export PRE_CTS_SIGMA_LOCAL="${PRE_CTS_SIGMA_LOCAL:-0.001}"
export PRE_CTS_MAX_SKEW="${PRE_CTS_MAX_SKEW:-0.100}"
export PRE_CTS_LAMBDA_REG="${PRE_CTS_LAMBDA_REG:-0.01}"
export PRE_CTS_HOLD_MARGIN="${PRE_CTS_HOLD_MARGIN:-0.003}"
export PRE_CTS_WEIGHT_IO="${PRE_CTS_WEIGHT_IO:-1.0}"

# --- Constraint Generation (V58: replaces TopK pruning for setup edges) ---
# Setup edges added iteratively when violated by current LP solution.
# Hold/IO constraints built upfront. Faster convergence on large designs.
#export CTS_ENABLE_CG — auto-detect in C++ (ON if n_ffs<=5000, OFF otherwise)

# --- Per-clock LP (separate LP per clock domain for multi-clock designs) ---
# Cross-clock edges form cyclic hold constraints → LP INFEASIBLE.
# Per-clock LP eliminates cross-clock edges → each clock solved independently.
export CTS_PER_CLOCK_LP="${CTS_PER_CLOCK_LP:-1}"

# --- Per-tier CTS + TARP clustering ---
export CTS_ENABLE_PER_TIER_CTS=1         # Independent H-trees per tier
export CTS_ENABLE_TARP=1                 # Timing-aware FM min-cut clustering
export CTS_TARP_ALPHA=0.7                # Timing vs spatial weight in TARP
export CTS_TARP_TOP_K=30                 # Top-K timing edges per FF for TARP graph
export CTS_TARP_SLACK_THRESH=0.3         # Slack threshold filter (× clock period)
export CTS_TARP_FM_PASSES=10             # FM refinement passes
export CTS_ENABLE_ITERATION=0            # Phase 3e iterative TAP refinement (marginal)

# --- Cascaded delay tap ---
export CTS_ENABLE_GH_TREE=1              # Cascaded TAP chain (50% fewer buffers vs parallel)
export CTS_ENABLE_GROUPED_DELAY=1        # Grouped delay within leaf clusters
export CTS_GROUPED_DELAY_MAX_DEPTH="${CTS_GROUPED_DELAY_MAX_DEPTH:-4}"
export CTS_GROUPED_DELAY_MIN_DELTA_NS=0.00
export CTS_GROUPED_DELAY_CLUSTER_UNIFORM=0  # Per-FF mode (not cluster-uniform)

# --- Features OFF ---
export CTS_ENABLE_PER_FF_RELAY=0         # Per-FF relay (replaced by grouped delay)
export CTS_ENABLE_TARGET_SPLIT=0         # Target-aware sub-clustering (V37, superseded by TARP)
export CTS_ENABLE_MID_DELAY_BUFS=0       # Intermediate delay buffers (V37)
export CTS_ENABLE_TIER_SPLIT=0           # Tier-aware cluster split (V48, superseded by per-tier CTS)
export CTS_ENABLE_LAYER_ASSIGNMENT=0     # Per-subnet metal layer assignment (no measurable benefit)

# --- DPL ---
export SKIP_HETERO_DPL="${SKIP_HETERO_DPL:-1}"  # Skip upper DPL for asap7_nangate45_3D (degrades timing 8-11x)

# --- Post-CTS LP + buffer sizing ---
export POST_CTS_MAX_SKEW="${POST_CTS_MAX_SKEW:-0.100}"
export POST_CTS_SIGMA_LOCAL="${POST_CTS_SIGMA_LOCAL:-0.005}"
export POST_CTS_HOLD_MARGIN="${POST_CTS_HOLD_MARGIN:-0.005}"
export POST_CTS_LAMBDA_REG="${POST_CTS_LAMBDA_REG:-0.001}"
export POST_CTS_SKEW_WEIGHT="${POST_CTS_SKEW_WEIGHT:-0.5}"
export HOLD_WEIGHT=0.5
export SIZING_MAX_ITERS=20
export SIZING_REFRESH_INTERVAL=10
export MAX_CONSEC_REJECTS=10
export HOLD_TNS_TOLERANCE=50.0
export SKIP_HOLD_GUARD=0
export LP_SETUP_MARGIN=0.0
export LP_HOLD_MARGIN=0.0
export CTS_AUTO_UPDATE_TAP=0
export CTS_ENABLE_HOLD_BUDGET_CAP=0    # Hold budget cap on TAP depth (default ON when hold budgets loaded)

# --- Speed optimization ---
export BATCH_TIMING=1
export PATH_LIMIT=10000          # fillTimingInfo/Batch: max(10000, PATH_LIMIT) — accuracy
export EXTRACT_PATH_LIMIT=500    # extractFFEdgesViaSTA: controls LP edge count.
                                 # Macro designs override in run.sh (ariane: 2000).
export EXTRACT_BATCH_SIZE=128    # adaptive split batching: K sources per findPathEnds call
# --- CSV paths for C++ HTreeBuilder hold budget loading ---
export CTS_TIMING_GRAPH_CSV="${RESULTS_DIR:-./results/${PLATFORM}/${DESIGN_NICKNAME}/openroad}/pre_cts_ff_timing_graph.csv"
export CTS_IO_TIMING_CSV="${RESULTS_DIR:-./results/${PLATFORM}/${DESIGN_NICKNAME}/openroad}/pre_cts_io_timing_edges.csv"

# --- Routing hook ---
export PRE_GLOBAL_ROUTE_TCL="${FLOW_ROOT:-${FLOW_HOME}}/scripts_openroad/pre_global_route_v43.tcl"
