+{
+  if (inst == nullptr) {
+    return false;
+  }
+  if (inst->isBlock()) {
+    return true;
+  }
+  const odb::dbMaster* master = inst->getMaster();
+  return (master != nullptr && master->isBlock())
+         || isNamedHardMacroMaster(master);
