+VerilogFFExtractor::VerilogFFExtractor(const std::string& verilog_path,
+                                       odb::dbBlock* block,
+                                       sta::dbSta* sta,
+                                       sta::dbNetwork* network,
+                                       utl::Logger* logger)
+    : verilog_path_(verilog_path), block_(block), sta_(sta), network_(network), logger_(logger)
