# post_route_debug_extract.tcl
# Post-Route CTS Debug Extraction — standalone script
#
# Runs AFTER routing. Loads 6_final.odb (contains all LEF/LIB/DEF/SDC)
# and reads 6_final.spef for post-route parasitics.
#
# Output files (in RESULTS_DIR, "postroute_debug_" prefix):
#   postroute_debug_per_ff.csv       — per-FF clock latency from routed RC
#   postroute_debug_clock_paths.csv  — per-FF clock path decomposition
#   postroute_debug_per_edge.csv     — per-edge LP skew vs actual skew
#   postroute_debug_buffers.csv      — clock buffer inventory
#   postroute_debug_summary.csv      — aggregate metrics
#
# Usage (standalone — only needs RESULTS_DIR and OPENROAD_SCRIPTS_DIR):
#   export RESULTS_DIR=<path to results/platform/design/openroad>
#   export OPENROAD_SCRIPTS_DIR=<path to scripts_openroad>
#   <openroad_exe> -threads 16 -exit post_route_debug_extract.tcl
#
# Or via run.sh Step 12 (automatic after ord-final).

puts "======================================================"
puts "  Post-Route CTS Debug Extraction"
puts "======================================================"

# ----------------------------------------------------------
# 1. Load design: ODB + liberty files + SDC
# ----------------------------------------------------------
# ODB contains LEF + DEF + placement, but NOT liberty (.lib).
# Liberty must be loaded separately for STA to work.
set _odb_file "$::env(RESULTS_DIR)/6_final.odb"
set _sdc_file "$::env(RESULTS_DIR)/6_final.sdc"

if {![file exists $_odb_file]} {
    puts "ERROR: 6_final.odb not found in $::env(RESULTS_DIR)"
    puts "  (Run ord-final first, or use final_report.tcl integration instead)"
    exit 1
}

# Load liberty: use LIB_FILES env if available (Makefile sets this),
# otherwise auto-discover from PLATFORM_DIR or FLOW_HOME.
if {[info exists ::env(LIB_FILES)] && $::env(LIB_FILES) ne ""} {
    puts "  Reading liberty from LIB_FILES env..."
    foreach _lib $::env(LIB_FILES) {
        read_liberty $_lib
    }
} else {
    # Auto-discover: PLATFORM_DIR > FLOW_HOME/platforms/<platform>
    set _platform_dir ""
    if {[info exists ::env(PLATFORM_DIR)]} {
        set _platform_dir $::env(PLATFORM_DIR)
    } elseif {[info exists ::env(FLOW_HOME)] && [info exists ::env(PLATFORM)]} {
        set _platform_dir "$::env(FLOW_HOME)/platforms/$::env(PLATFORM)"
    } else {
        # Infer from OPENROAD_SCRIPTS_DIR (scripts_openroad -> flow root)
        set _flow_root [file dirname $::env(OPENROAD_SCRIPTS_DIR)]
        # Infer platform from RESULTS_DIR path: .../results/<platform>/<design>/openroad
        set _rparts [file split $::env(RESULTS_DIR)]
        set _ridx [lsearch $_rparts "results"]
        if {$_ridx >= 0 && $_ridx + 1 < [llength $_rparts]} {
            set _platform [lindex $_rparts [expr {$_ridx + 1}]]
            set _platform_dir "$_flow_root/platforms/$_platform"
        }
    }
    if {$_platform_dir ne "" && [file isdirectory $_platform_dir]} {
        puts "  Auto-discovering liberty from: $_platform_dir"
        set _libs [concat \
            [glob -nocomplain "$_platform_dir/lib_bottom/NLDM/*.lib"] \
            [glob -nocomplain "$_platform_dir/lib_upper/NLDM/*.lib"] \
            [glob -nocomplain "$_platform_dir/lib/NLDM/*.lib"] \
            [glob -nocomplain "$_platform_dir/lib/*.lib"]]
        if {[llength $_libs] == 0} {
            puts "ERROR: No .lib files found under $_platform_dir"
            exit 1
        }
        foreach _lib $_libs {
            read_liberty $_lib
        }
        puts "  Loaded [llength $_libs] liberty files"
    } else {
        puts "ERROR: Cannot find liberty files. Set LIB_FILES or PLATFORM_DIR env."
        exit 1
    }
}

# Load ODB (LEF + DEF + placement)
puts "  Loading ODB: $_odb_file"
read_db $_odb_file

# Load SDC
if {[file exists $_sdc_file]} {
    read_sdc $_sdc_file
    puts "  Loaded SDC: $_sdc_file"
} else {
    puts "  WARNING: SDC not found ($_sdc_file), timing may be incomplete"
}

# Propagated clock mode (required for accurate post-route latency)
set_propagated_clock [all_clocks]

# ----------------------------------------------------------
# 2. Parasitics: SPEF read > RCX inline > fallback
# ----------------------------------------------------------
set _spef_file "$::env(RESULTS_DIR)/6_final.spef"
set _parasitics_source "unknown"

if {[file exists $_spef_file]} {
    # Best: SPEF already generated by final_report.tcl
    puts "  Reading existing SPEF: $_spef_file"
    read_spef $_spef_file
    set _parasitics_source "spef_6_final"
} elseif {[info exists ::env(RCX_RULES)] && [file exists $::env(RCX_RULES)]} {
    # Run RCX extraction inline
    puts "  Running RCX extraction (RCX_RULES=$::env(RCX_RULES))..."
    define_process_corner -ext_model_index 0 X
    extract_parasitics -ext_model_file $::env(RCX_RULES)
    write_spef $_spef_file
    puts "  SPEF written to $_spef_file"
    read_spef $_spef_file
    catch {file delete $::env(DESIGN_NAME).totCap}
    set _parasitics_source "rcx_inline"
} else {
    # Fallback: global routing estimate
    puts "  WARNING: No SPEF and no RCX_RULES. Using global_routing estimate."
    estimate_parasitics -global_routing
    set _parasitics_source "global_routing_estimate"
}
puts "  Parasitics source: $_parasitics_source"

# ----------------------------------------------------------
# 3. Source debug extraction procs and run
# ----------------------------------------------------------
source $::env(OPENROAD_SCRIPTS_DIR)/cts_debug_extract.tcl

set results_dir $::env(RESULTS_DIR)

# Load LP targets (if available from CTS stage)
set lp_csv "$results_dir/pre_cts_skew_targets.csv"
set lp_targets [cts_debug_read_lp_targets $lp_csv]
puts "  LP targets: [dict size $lp_targets] FFs"

puts "\n######################################################"
puts "# Post-Route CTS Debug Extraction (5 CSV files)"
puts "# Parasitics: $_parasitics_source"
puts "######################################################"

# 1. Per-FF latency (post-route RC)
set ff_csv "$results_dir/postroute_debug_per_ff.csv"
extract_ff_clock_latency $ff_csv $lp_targets

# 2. Clock path decomposition (post-route RC)
extract_clock_path_via_sta "$results_dir/postroute_debug_clock_paths.csv"

# 3. Per-edge skew analysis
set graph_csv "$results_dir/pre_cts_ff_timing_graph.csv"
extract_per_edge $ff_csv $graph_csv $lp_targets "$results_dir/postroute_debug_per_edge.csv"

# 4. Buffer inventory
extract_buffer_inventory $lp_targets "$results_dir/postroute_debug_buffers.csv"

# 5. Summary (post-route timing)
extract_debug_summary "$results_dir/postroute_debug_summary.csv"

puts "\n>>> Post-Route Debug: 5 CSV files written"
puts "    Per-FF:    $results_dir/postroute_debug_per_ff.csv"
puts "    Paths:     $results_dir/postroute_debug_clock_paths.csv"
puts "    Per-Edge:  $results_dir/postroute_debug_per_edge.csv"
puts "    Buffers:   $results_dir/postroute_debug_buffers.csv"
puts "    Summary:   $results_dir/postroute_debug_summary.csv"
puts "    Source:    $_parasitics_source"

exit
